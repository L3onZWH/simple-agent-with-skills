# 必填：Anthropic API Key（或兼容服务的密钥）
ANTHROPIC_API_KEY=

# 可选：覆盖官方 API 根地址（代理 / 自建网关 / 兼容端点）
# 官方默认由 SDK 处理；若需替换，填写完整 origin，例如：
# ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_BASE_URL=

# 可选：模型 ID（需与网关支持的名称一致）
ANTHROPIC_MODEL=claude-sonnet-4-6

# 可选：技能目录（默认 ./skills）
# SKILLS_DIR=/path/to/skills




